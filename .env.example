# ==============================================================================
# MC-Terrarium Environment Configuration Example
# ==============================================================================
# Copy this file to .env and adjust values as needed.
#
# Usage:
#   docker compose up -d
# ==============================================================================

# OpenBao / OpenTofu vault provider token
# - Persistent mode: set automatically by ./init/init-openbao.sh
# - Dev mode: sets the initial root token via BAO_DEV_ROOT_TOKEN_ID
# Used by docker-compose.yaml, OpenTofu vault provider, and host-side API calls.
# Note: BAO_TOKEN was replaced by VAULT_TOKEN for OpenTofu vault provider compatibility.
VAULT_TOKEN=                      # OpenBao root token (auto-set in persistent mode)
VAULT_ADDR=http://localhost:8200  # OpenBao API address (host-side; overridden inside Docker)

# OpenBao image override (optional)
# To use a UI-enabled image built from third-party/openbao-ui/Dockerfile:
#   docker build -f third-party/openbao-ui/Dockerfile -t openbao:dev-ui .
# Then uncomment the line below:
# OPENBAO_IMAGE=openbao:dev-ui

# MC-Terrarium API username and password
TERRARIUM_API_USERNAME= # MC-Terrarium REST API username 
TERRARIUM_API_PASSWORD= # MC-Terrarium REST API password
